total_memory=$(free | grep Mem | awk '{ print $2 }')
free_memory=$(free | grep Mem | awk '{ print $3 }')

percentage=$(bc <<< "scale=2; $free_memory/$total_memory*100" | awk -F. '{ print $1 }')

echo " $percentage%"
